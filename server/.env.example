# Server Configuration
PORT=5000
NODE_ENV=development

# MongoDB Connection
MONGODB_URI=mongodb://localhost:27017/arlinjai_paradise
# For MongoDB Atlas:
# MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/arlinjai_paradise

# JWT Configuration
JWT_SECRET=your_super_secret_jwt_key_change_in_production_arlinjai_2024
JWT_EXPIRE=7d

# Email Configuration (Nodemailer / Gmail SMTP)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_gmail_app_password
EMAIL_FROM=Arlinjai Paradise <info@arlinjaiparadise.com>

# Admin Default Credentials (change after first login)
ADMIN_EMAIL=admin@arlinjaiparadise.com
ADMIN_PASSWORD=Admin@2024

# Hotel Info (for email templates)
HOTEL_NAME=Arlinjai Paradise
HOTEL_PHONE=9486271234
HOTEL_EMAIL=info@arlinjaiparadise.com
HOTEL_ADDRESS=No. 5/69, Beach Road, Kanyakumari – 629702

# Frontend URL (for CORS)
CLIENT_URL=http://localhost:3000

# File Upload
MAX_FILE_SIZE=5242880
UPLOAD_PATH=uploads/

# Firebase Admin SDK (paste full service account JSON as single line)
FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...","private_key":"...","client_email":"..."}

# Razorpay Payment Gateway
# Get your keys from: https://dashboard.razorpay.com/app/keys
RAZORPAY_KEY_ID=rzp_test_XXXXXXXXXXXXXXXX
RAZORPAY_KEY_SECRET=XXXXXXXXXXXXXXXXXXXXXXXX
